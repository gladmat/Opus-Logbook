{
  "name": "opus",
  "main": "client/index.js",
  "version": "1.0.0",
  "scripts": {
    "dev:mobile": "node scripts/dev-mobile.js",
    "expo:dev": "EXPO_PUBLIC_API_URL=http://localhost:5001 npx expo start --host lan --port 8083",
    "server:dev": "NODE_ENV=development node --watch --env-file=.env --import tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "node scripts/server-build.js",
    "server:prod": "NODE_ENV=production node server_dist/index.mjs",
    "db:push": "node --env-file=.env ./node_modules/.bin/drizzle-kit push",
    "db:generate": "node --env-file=.env ./node_modules/.bin/drizzle-kit generate",
    "db:migrate": "node --env-file=.env ./node_modules/.bin/drizzle-kit migrate",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "check:types": "tsc --noEmit",
    "check:format": "prettier --check \"**/*.{js,ts,tsx,css,json}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prepare": "husky"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@noble/ciphers": "2.1.1",
    "@noble/curves": "2.0.1",
    "@noble/hashes": "2.0.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@sentry/node": "^10.51.0",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "^2.3.0",
    "@types/uuid": "^10.0.0",
    "expo": "^54.0.23",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.9",
    "expo-crypto": "^15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-mail-composer": "^15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-secure-store": "^15.0.8",
    "expo-server-sdk": "^6.1.0",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "posthog-react-native": "^4.44.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "4.2.0",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "24.10.0",
    "@types/pg": "^8.18.0",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-prettier": "^5.5.4",
    "expo-mcp": "~0.2.1",
    "express": "^4.21.2",
    "husky": "^9.1.7",
    "jose": "^6.2.2",
    "lint-staged": "^15.5.2",
    "multer": "^2.1.0",
    "pg": "^8.16.3",
    "pino-pretty": "^13.1.3",
    "prettier": "3.6.2",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.1.0",
    "resend": "^4.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "private": true,
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}

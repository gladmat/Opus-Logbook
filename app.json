{
  "expo": {
    "name": "Opus",
    "slug": "surgical-logbook",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./client/assets/icons/app/opus-icon-1024.png",
    "scheme": "opus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drgladysz.opus",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0C0F14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.drgladysz.opus",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#0C0F14",
          "dark": {
            "backgroundColor": "#0C0F14"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Opus needs access to your photo library to attach operative images to cases.",
          "cameraPermission": "Opus needs access to your camera to capture intraoperative photos."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "0bc1b91c-c240-4f4e-b030-31d16389cd1e"
      }
    },
    "owner": "gladmat"
  }
}

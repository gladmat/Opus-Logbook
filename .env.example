# Opus environment variables
# Copy to `.env` (which is gitignored) and fill in real values.
# Schema is enforced by server/env.ts at boot — bad/missing values exit non-zero.

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection. Local dev typically:
#   postgresql://postgres@localhost:5432/opus_dev
DATABASE_URL=postgresql://postgres@localhost:5432/opus_dev

# JWT signing secret — minimum 32 characters. Generate with:
#   openssl rand -hex 48
# In production, env.ts rejects values containing dev/example phrases like
# `local-dev`, `change-in-production`, `change-me`, `test-secret`, etc.
JWT_SECRET=replace-with-openssl-rand-hex-48-output-min-32-chars

# Port the Express server listens on. Use 5001 locally — port 5000 conflicts
# with macOS AirPlay receiver.
PORT=5001

# `development` | `production` | `test`. Affects env validation strictness,
# logger output (pino-pretty in dev, JSON in prod), Sentry sampling.
NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — feature unlocks
# ──────────────────────────────────────────────────────────────────────────────

# Resend API key for transactional email (password reset, welcome,
# invitation). Without this, those endpoints will throw at send time.
# RESEND_API_KEY=re_xxxxx

# Override the URL used in email templates. Without this, the server falls
# back to RAILWAY_PUBLIC_DOMAIN (auto-injected on Railway) or the production
# domain.
# APP_DOMAIN=https://staging.example.com

# Auto-injected by Railway in production deploys. Don't set locally.
# RAILWAY_PUBLIC_DOMAIN=

# Dev-only SNOMED CT seed endpoint gate. Set both to enable
# POST /api/seed-snomed-ref. Production should NOT set these.
# ENABLE_SEED=true
# SEED_TOKEN=any-long-random-string

# EAS / Expo automation token — only needed for CI workflows that interact
# with EAS submit. Local dev does not need this.
# EXPO_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (optional but strongly recommended in prod)
# ──────────────────────────────────────────────────────────────────────────────

# Sentry server-side DSN. When unset, server/sentry.ts is a no-op so the app
# runs identically without a Sentry account. Get one at sentry.io.
# SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/yyyyy

# Pino log level. Default is `info` outside tests. Use `debug` to see request
# debug lines (baseUrl, expoDeepLink). Use `silent` to suppress everything.
# LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────────────────────
# CLIENT (Expo) — variables exposed to the React Native bundle
# ──────────────────────────────────────────────────────────────────────────────
# These are read by the Expo runtime, NOT the Express server. They MUST be
# prefixed with `EXPO_PUBLIC_` to be embedded in the client bundle. Anything
# without that prefix stays server-side. Never put server secrets behind the
# `EXPO_PUBLIC_` prefix — the client bundle is shipped to App Store users.

# API base URL for the React Native client. The dev script sets this to
# http://localhost:5001 automatically.
# EXPO_PUBLIC_API_URL=http://localhost:5001

# Sentry client DSN (separate project from server). Optional.
# EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/zzzzz
